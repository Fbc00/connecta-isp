{
  "name": "connecta-isp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Monolito React (Vite) + Express + SQLite — raiz só orquestra build/test/lint",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch server/index.ts",
    "dev:client": "vite client",
    "build": "vite build client",
    "start": "NODE_ENV=production bun server/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p client/tsconfig.json --noEmit",
    "test": "DB_PATH=:memory: bun test",
    "test:watch": "DB_PATH=:memory: bun test --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
